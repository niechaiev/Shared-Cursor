# EditorConfig — https://editorconfig.org
# VRenaissance Unity Project — C# code style
# Derived from reading Assets/QualiumSystems/Scripts/**/*.cs
root = true

# ── All files ───────────────────────────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = crlf
indent_style             = space
insert_final_newline     = true
trim_trailing_whitespace = true

# ── Data / config files ─────────────────────────────────────────────────────
[*.{json,asmdef,asmref}]
indent_size = 2

[*.{yaml,yml}]
indent_size = 2

[*.xml]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# ── C# ───────────────────────────────────────────────────────────────────────
[*.cs]
indent_size = 4

# ── Using directives ────────────────────────────────────────────────────────
# Observed order: System → Oculus/Meta → QualiumSystems → SolidUtilities → UnityEngine → Zenject
csharp_using_directive_placement        = outside_namespace:warning
dotnet_sort_system_directives_first     = true
dotnet_separate_import_directive_groups = false

# ── this. qualification (never used) ────────────────────────────────────────
dotnet_style_qualification_for_field    = false:silent
dotnet_style_qualification_for_property = false:silent
dotnet_style_qualification_for_method   = false:silent
dotnet_style_qualification_for_event    = false:silent

# ── Language keywords vs BCL type names ─────────────────────────────────────
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access             = true:warning

# ── Modifiers ───────────────────────────────────────────────────────────────
dotnet_style_require_accessibility_modifiers = always:warning
dotnet_style_readonly_fields                 = true:suggestion
csharp_preferred_modifier_order = public, private, protected, internal, static, extern, new, virtual, abstract, sealed, override, readonly, unsafe, volatile, async:suggestion

# ── Null-checks and coalescing ───────────────────────────────────────────────
dotnet_style_null_propagation                                    = true:suggestion
dotnet_style_coalesce_expression                                 = true:suggestion
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning
csharp_style_throw_expression                                    = true:suggestion
csharp_style_conditional_delegate_call                           = true:suggestion

# ── Expression-level preferences ─────────────────────────────────────────────
dotnet_style_object_initializer                            = true:suggestion
dotnet_style_collection_initializer                        = true:suggestion
dotnet_style_explicit_tuple_names                          = true:suggestion
dotnet_style_prefer_inferred_tuple_names                   = true:suggestion
dotnet_style_prefer_inferred_anonymous_type_member_names   = true:suggestion
dotnet_style_prefer_auto_properties                        = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:silent
dotnet_style_prefer_conditional_expression_over_return     = false:silent

# ── var usage ────────────────────────────────────────────────────────────────
# Always prefer var — used even for built-in types and non-obvious returns
csharp_style_var_for_built_in_types    = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere             = true:suggestion

# Rider / ReSharper var preferences (resharper_* keys take effect in Rider)
resharper_for_built_in_types = use_var
resharper_for_simple_types   = use_var
resharper_for_other_types    = use_var

# ── Expression-bodied members ────────────────────────────────────────────────
# Single-line properties use expression bodies; constructors do not.
# Method bodies (block vs expression) are left to developer choice — no enforcement.
csharp_style_expression_bodied_methods       = when_on_single_line:silent
csharp_style_expression_bodied_constructors  = false:suggestion
csharp_style_expression_bodied_operators     = when_on_single_line:suggestion
csharp_style_expression_bodied_properties    = when_on_single_line:suggestion
csharp_style_expression_bodied_indexers      = when_on_single_line:suggestion
csharp_style_expression_bodied_accessors     = when_on_single_line:suggestion
csharp_style_expression_bodied_lambdas       = when_on_single_line:silent
csharp_style_expression_bodied_local_functions = false:silent

# ── Pattern matching ─────────────────────────────────────────────────────────
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check  = true:suggestion
csharp_style_prefer_switch_expression                  = true:suggestion
csharp_style_prefer_pattern_matching                   = true:suggestion
csharp_style_prefer_not_pattern                        = true:suggestion

# ── Braces ───────────────────────────────────────────────────────────────────
# Allman style: opening brace on its own line for all blocks
csharp_new_line_before_open_brace                      = all
csharp_new_line_before_else                            = true
csharp_new_line_before_catch                           = true
csharp_new_line_before_finally                         = true
csharp_new_line_before_members_in_object_initializers  = true
csharp_new_line_before_members_in_anonymous_types      = true
csharp_new_line_between_query_expression_clauses       = true
csharp_prefer_braces                                   = when_multiline:suggestion

# ── Indentation ──────────────────────────────────────────────────────────────
csharp_indent_case_contents            = true
csharp_indent_switch_labels            = true
csharp_indent_labels                   = flush_left
csharp_indent_block_contents           = true
csharp_indent_braces                   = false
csharp_indent_case_contents_when_block = false

# ── Spacing ──────────────────────────────────────────────────────────────────
csharp_space_after_cast                                              = false
csharp_space_after_keywords_in_control_flow_statements               = true
csharp_space_between_parentheses                                     = false
csharp_space_before_colon_in_inheritance_clause                      = true
csharp_space_after_colon_in_inheritance_clause                       = true
csharp_space_around_binary_operators                                 = before_and_after
csharp_space_between_method_declaration_parameter_list_parentheses   = false
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_declaration_name_and_open_parenthesis    = false
csharp_space_between_method_call_parameter_list_parentheses          = false
csharp_space_between_method_call_empty_parameter_list_parentheses    = false
csharp_space_between_method_call_name_and_opening_parenthesis        = false
csharp_space_after_comma                                             = true
csharp_space_before_comma                                            = false
csharp_space_after_dot                                               = false
csharp_space_before_dot                                              = false
csharp_space_after_semicolon_in_for_statement                        = true
csharp_space_before_semicolon_in_for_statement                       = false
csharp_space_around_declaration_statements                           = false
csharp_space_before_open_square_brackets                             = false
csharp_space_between_empty_square_brackets                           = false
csharp_space_between_square_brackets                                 = false

# ── Wrapping ─────────────────────────────────────────────────────────────────
csharp_preserve_single_line_statements = true
csharp_preserve_single_line_blocks     = true

# Rider / ReSharper single-line statement placement
resharper_csharp_place_simple_embedded_statement_on_single_line = true

# ── Namespace style ──────────────────────────────────────────────────────────
csharp_style_namespace_declarations = block_scoped:warning

# ── Misc C# preferences ──────────────────────────────────────────────────────
csharp_prefer_simple_using_statement        = false:suggestion
csharp_style_prefer_method_group_conversion = true:suggestion
csharp_prefer_static_local_function         = true:suggestion

# ── Naming rules ─────────────────────────────────────────────────────────────
# Rules are evaluated top-to-bottom; first match wins.

# Interfaces → IPascalCase
dotnet_naming_rule.interfaces.symbols  = symbol_interface
dotnet_naming_rule.interfaces.style    = style_i_prefix_pascal
dotnet_naming_rule.interfaces.severity = warning

dotnet_naming_symbols.symbol_interface.applicable_kinds          = interface
dotnet_naming_symbols.symbol_interface.applicable_accessibilities = *

dotnet_naming_style.style_i_prefix_pascal.required_prefix = I
dotnet_naming_style.style_i_prefix_pascal.capitalization   = pascal_case

# Private const fields → PascalCase  (e.g., DefaultButtonDistance, Size)
dotnet_naming_rule.private_const_fields.symbols  = symbol_private_const_field
dotnet_naming_rule.private_const_fields.style    = style_pascal
dotnet_naming_rule.private_const_fields.severity = suggestion

dotnet_naming_symbols.symbol_private_const_field.applicable_kinds          = field
dotnet_naming_symbols.symbol_private_const_field.applicable_accessibilities = private
dotnet_naming_symbols.symbol_private_const_field.required_modifiers        = const

# Private fields → _camelCase
# Note: [SerializeField] private fields conventionally use camelCase (no underscore)
# because Unity serialization uses the field name as the display label.
# EditorConfig cannot filter by attribute, so this rule covers the majority pattern
# for non-serialized private fields. Set to suggestion to avoid false positives on
# serialized fields.
dotnet_naming_rule.private_fields.symbols  = symbol_private_field
dotnet_naming_rule.private_fields.style    = style_underscore_camel
dotnet_naming_rule.private_fields.severity = suggestion

dotnet_naming_symbols.symbol_private_field.applicable_kinds          = field
dotnet_naming_symbols.symbol_private_field.applicable_accessibilities = private

dotnet_naming_style.style_underscore_camel.required_prefix = _
dotnet_naming_style.style_underscore_camel.capitalization  = camel_case

# Public/protected/internal members → PascalCase
dotnet_naming_rule.public_members.symbols  = symbol_public_member
dotnet_naming_rule.public_members.style    = style_pascal
dotnet_naming_rule.public_members.severity = warning

dotnet_naming_symbols.symbol_public_member.applicable_kinds          = property, method, field, event, delegate
dotnet_naming_symbols.symbol_public_member.applicable_accessibilities = public, protected, internal, protected_internal

dotnet_naming_style.style_pascal.capitalization = pascal_case

# Types (class, struct, enum, delegate) → PascalCase
dotnet_naming_rule.types.symbols  = symbol_type
dotnet_naming_rule.types.style    = style_pascal
dotnet_naming_rule.types.severity = warning

dotnet_naming_symbols.symbol_type.applicable_kinds          = class, struct, enum, delegate
dotnet_naming_symbols.symbol_type.applicable_accessibilities = *

# Parameters and local variables → camelCase
dotnet_naming_rule.locals_and_params.symbols  = symbol_local
dotnet_naming_rule.locals_and_params.style    = style_camel
dotnet_naming_rule.locals_and_params.severity = suggestion

dotnet_naming_symbols.symbol_local.applicable_kinds          = parameter, local
dotnet_naming_symbols.symbol_local.applicable_accessibilities = *

dotnet_naming_style.style_camel.capitalization = camel_case

# Type parameters → TPascalCase
dotnet_naming_rule.type_parameters.symbols  = symbol_type_param
dotnet_naming_rule.type_parameters.style    = style_t_prefix_pascal
dotnet_naming_rule.type_parameters.severity = suggestion

dotnet_naming_symbols.symbol_type_param.applicable_kinds = type_parameter

dotnet_naming_style.style_t_prefix_pascal.required_prefix = T
dotnet_naming_style.style_t_prefix_pascal.capitalization  = pascal_case
